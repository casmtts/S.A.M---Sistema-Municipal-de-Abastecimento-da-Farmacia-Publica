generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  ADMIN
  GESTOR
  FARMACEUTICO
  ATENDENTE
  CONSULTOR
}

model Usuario {
  id           String    @id @default(uuid())
  nome         String
  email        String    @unique
  cpf          String    @unique
  senha        String
  role         UserRole  @default(ATENDENTE)
  ativo        Boolean   @default(true)
  telefone     String?
  cargo        String?
  unidadeId    String?
  ultimoAcesso DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@map("usuarios")
}